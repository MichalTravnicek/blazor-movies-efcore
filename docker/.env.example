# MS SQL Server Docker configuration
# Copy this file to .env and adjust the values.
# The .env file is gitignored (contains secrets).

# SA (System Administrator) password — must be at least 8 chars
# and include uppercase, lowercase, digits, and special characters
MSSQL_SA_PASSWORD=YourStrong!Passw0rd

# SQL Server edition: Developer, Express, Standard, Enterprise
MSSQL_PID=Developer

# Set to Y to accept the SQL Server EULA (required)
ACCEPT_EULA=Y