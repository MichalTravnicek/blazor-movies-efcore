@using Microsoft.AspNetCore.Components.Authorization

@if (authState?.User.Identity?.IsAuthenticated != true)
{
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow">
                    <div class="card-body p-4 text-center">
                        <h3 class="card-title mb-3">User Management</h3>
                        <p class="text-muted">You need to be signed in as an administrator to access this page.</p>
                        <a href="/" class="btn btn-primary">Go to Home</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow">
                    <div class="card-body p-4 text-center">
                        <h3 class="card-title mb-3">Access Denied</h3>
                        <p class="text-muted">You are signed in but do not have administrator privileges.</p>
                        <a href="/" class="btn btn-primary">Go to Home</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter]
    private AuthenticationState? authState { get; set; }
}
