@if (!string.IsNullOrEmpty(PosterUrl))
{
    <img src="@PosterUrl" alt="@AltText" class="@Class" />
}
else
{
    <div class="movie-poster-placeholder @Class">
        <span>🎬</span>
        <small>@AltText</small>
    </div>
}

@code {
    /// <summary>
    /// The poster image URL to display. Null/empty renders a placeholder.
    /// </summary>
    [Parameter]
    public string? PosterUrl { get; set; }

    /// <summary>
    /// Alt text for the image or placeholder label.
    /// </summary>
    [Parameter]
    public string AltText { get; set; } = "";

    /// <summary>
    /// Additional CSS classes to apply to the poster element.
    /// </summary>
    [Parameter]
    public string Class { get; set; } = "";
}
