@page "/movies"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.QuickGrid
@inject IHttpClientFactory HttpClientFactory
@using BlazorWebAppMovies.Components.Shared

<PageTitle>Index</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <input type="search" class="form-control form-control-sm w-auto" @bind="titleFilter" @bind:event="oninput" placeholder="Search by title..." />
    @if (authState?.User.Identity?.IsAuthenticated == true)
    {
        <a href="movies/create" class="btn btn-primary btn-sm">+ Create New</a>
        <button class="btn btn-outline-info btn-sm ms-1" @onclick="BackfillPosters" disabled="@isBackfilling">
            @if (isBackfilling)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            }
            Fetch Missing Posters
        </button>
    }
</div>

<div>
    <QuickGrid Class="table table-striped table-hover" Items="FilteredMovies" Pagination="pagination">
        <TemplateColumn Title="Poster" Context="movie">
            @if (!string.IsNullOrEmpty(movie.PosterUrl))
            {
                <img src="@GetPosterThumbUrl(movie.PosterUrl)" alt="@movie.Title poster"
                     class="movie-poster-thumb" style="height:60px;cursor:pointer;"
                     @onclick="() => OpenLightbox(movie)" />
            }
            else
            {
                <div class="movie-poster-thumb-placeholder" style="height:60px;width:40px;">
                    <span>🎬</span>
                </div>
            }
        </TemplateColumn>
        <PropertyColumn Property="movie => movie.Title" Sortable="true" />
        <PropertyColumn Property="movie => movie.ReleaseDate" Title="Release Date" />
        <PropertyColumn Property="movie => movie.Genre" />
        <PropertyColumn Property="movie => movie.Price" />
        <PropertyColumn Property="movie => movie.Rating" />

        <TemplateColumn Context="movie">
            <div class="d-flex gap-1">
                @if (authState?.User.Identity?.IsAuthenticated == true)
                {
                    <a href="@($"movies/edit?id={movie.Id}")" class="btn btn-sm btn-warning">Edit</a>
                }
                <a href="@($"movies/details?id={movie.Id}")" class="btn btn-sm btn-info">Details</a>
                @if (authState?.User.Identity?.IsAuthenticated == true)
                {
                    <a href="@($"movies/delete?id={movie.Id}")" class="btn btn-sm btn-outline-danger">Delete</a>
                }
            </div>
        </TemplateColumn>
    </QuickGrid>
</div>

<Paginator State="pagination" />

@if (lightboxMovie is not null)
{
    <Lightbox @ref="lightbox">
        @if (isLightboxLoading)
        {
            <div class="d-flex justify-content-center align-items-center" style="min-height:300px;">
                <div class="spinner-border text-light" role="status" style="width:3rem;height:3rem;">
                    <span class="visually-hidden">Loading poster...</span>
                </div>
            </div>
        }
        <img src="@GetFullPosterUrl(lightboxMovie.PosterUrl)" alt="@lightboxMovie.Title poster"
             class="img-fluid" style="max-height:80vh;@(isLightboxLoading ? "display:none;" : "")"
             @onload="OnLightboxImageLoaded" />
    </Lightbox>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private AuthenticationState? authState;
    private List<MovieDto> movies = [];
    private PaginationState pagination = new PaginationState { ItemsPerPage = 5 };
    private string titleFilter = string.Empty;
    private bool isBackfilling;
    private bool isLightboxLoading;
    private bool _pendingLightboxOpen;
    private Lightbox? lightbox;
    private MovieDto? lightboxMovie;

    private IQueryable<MovieDto> FilteredMovies =>
        movies.AsQueryable().Where(m => m.Title.Contains(titleFilter, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask is not null)
        {
            authState = await AuthStateTask;
        }

        await LoadMovies();
    }

    private async Task LoadMovies()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("BlazorApi");
            var request = new HttpRequestMessage(HttpMethod.Get, "/api/movies");
            request.Headers.TryAddWithoutValidation("Accept", "application/json");

            var response = await client.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                movies = await response.Content.ReadFromJsonAsync<List<MovieDto>>() ?? [];
            }
        }
        catch
        {
            // Silently keep empty list on failure — UI shows an empty table
        }
    }

    private async Task BackfillPosters()
    {
        isBackfilling = true;
        try
        {
            var client = HttpClientFactory.CreateClient("BlazorApi");
            var response = await client.PostAsync("/api/movies/poster/backfill", null);
            if (response.IsSuccessStatusCode)
            {
                await LoadMovies();
            }
        }
        catch
        {
            // Silently handle — button re-enables on finally
        }
        finally
        {
            isBackfilling = false;
        }
    }

    private string? GetPosterThumbUrl(string? posterUrl)
    {
        if (string.IsNullOrEmpty(posterUrl))
            return null;

        // If it's a TMDB URL, request a smaller size for the thumbnail
        if (posterUrl.Contains("image.tmdb.org"))
        {
            return posterUrl.Replace("/w500", "/w92");
        }

        return posterUrl;
    }

    private void OpenLightbox(MovieDto movie)
    {
        Console.WriteLine($"[Index] OpenLightbox: movie={movie.Id} '{movie.Title}', lightbox ref is null? {lightbox is null}");
        lightboxMovie = movie;
        isLightboxLoading = true;
        _pendingLightboxOpen = true;
        Console.WriteLine("[Index] Set _pendingLightboxOpen=true, waiting for OnAfterRender");
    }
protected override void OnAfterRender(bool firstRender)
{
    if (_pendingLightboxOpen)
    {
        Console.WriteLine($"[Details] OnAfterRender: lightbox ref is null? {lightbox is null}, calling Open()");
        if (lightbox is not null)
        {
            _pendingLightboxOpen = false;
            lightbox.Open();
        }
        else
        {
            Console.WriteLine("[Details] WARNING: lightbox ref still null after render!");
        }
    }
}

    private void OnLightboxImageLoaded()
    {
        Console.WriteLine("[Index] Lightbox image loaded, hiding spinner");
        isLightboxLoading = false;
        StateHasChanged();
    }

    private string? GetFullPosterUrl(string? posterUrl)
    {
        if (string.IsNullOrEmpty(posterUrl))
            return null;

        // For TMDB URLs, use w500 for the lightbox
        if (posterUrl.Contains("image.tmdb.org"))
        {
            return posterUrl;
        }

        return posterUrl;
    }
}
