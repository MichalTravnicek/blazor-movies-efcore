@page "/movies/edit"
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<hr />
@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else if (Movie is null)
{
    <p><em>Movie not found.</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm Model="Movie" OnValidSubmit="UpdateMovie" FormName="edit">
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <div class="mb-3">
                    <label for="title" class="form-label">Title:</label>
                    <InputText id="title" @bind-Value="Movie.Title" class="form-control" />
                    <ValidationMessage For="() => Movie.Title" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="releasedate" class="form-label">Release Date:</label>
                    <InputDate id="releasedate" @bind-Value="Movie.ReleaseDate" class="form-control" />
                    <ValidationMessage For="() => Movie.ReleaseDate" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="genre" class="form-label">Genre:</label>
                    <InputText id="genre" @bind-Value="Movie.Genre" class="form-control" />
                    <ValidationMessage For="() => Movie.Genre" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="price" class="form-label">Price:</label>
                    <InputNumber id="price" @bind-Value="Movie.Price" class="form-control" />
                    <ValidationMessage For="() => Movie.Price" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="rating" class="form-label">Rating:</label>
                    <select id="rating" class="form-select" @bind="Movie.Rating">
                        <option value="">Select rating...</option>
                        <option value="G">G</option>
                        <option value="PG">PG</option>
                        <option value="PG-13">PG-13</option>
                        <option value="R">R</option>
                        <option value="NC-17">NC-17</option>
                    </select>
                    <ValidationMessage For="() => Movie.Rating" class="text-danger" />
                </div>
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="text-danger mb-2">@errorMessage</div>
                }
                <div class="d-flex gap-1">
                    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        Save
                    </button>
                    <a href="/movies" class="btn btn-outline-secondary">Back to List</a>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery]
    private int Id { get; set; }

    private UpdateMovieDto? Movie { get; set; }
    private bool isLoading = true;
    private bool isSubmitting;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadMovie();
    }

    private async Task LoadMovie()
    {
        isLoading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("BlazorApi");
            var movie = await client.GetFromJsonAsync<MovieDto>($"/api/movies/{Id}");

            if (movie is null)
            {
                NavigationManager.NavigateTo("/notfound");
                return;
            }

            Movie = new UpdateMovieDto
            {
                Title = movie.Title,
                Genre = movie.Genre,
                Price = movie.Price,
                ReleaseDate = movie.ReleaseDate,
                Rating = movie.Rating
            };
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            NavigationManager.NavigateTo("/notfound");
        }
        catch
        {
            // Stay on page — Movie stays null, UI shows "Movie not found."
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateMovie()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var client = HttpClientFactory.CreateClient("BlazorApi");
            var response = await client.PutAsJsonAsync($"/api/movies/{Id}", Movie);

            if (response.IsSuccessStatusCode)
            {
                NavigationManager.NavigateTo("/movies");
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                errorMessage = error?.Message ?? "A movie with this title already exists.";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                NavigationManager.NavigateTo("/notfound");
            }
            else
            {
                errorMessage = "An error occurred while saving the movie.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

}
