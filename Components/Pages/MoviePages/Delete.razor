@page "/movies/delete"
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <hr />
    @if (isLoading)
    {
        <p><em>Loading...</em></p>
    }
    else if (_movie is null)
    {
        <p><em>Movie not found.</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Title</dt>
            <dd class="col-sm-10">@_movie.Title</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Release Date</dt>
            <dd class="col-sm-10">@_movie.ReleaseDate</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Genre</dt>
            <dd class="col-sm-10">@_movie.Genre</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Price</dt>
            <dd class="col-sm-10">@_movie.Price</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Rating</dt>
            <dd class="col-sm-10">@_movie.Rating</dd>
        </dl>
        <EditForm Model="_movie" OnValidSubmit="DeleteMovie" FormName="delete">
            <div class="d-flex gap-1">
                <button type="submit" class="btn btn-danger" disabled="@(isSubmitting || _movie is null)">
                    @if (isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Delete
                </button>
                <a href="/movies" class="btn btn-outline-secondary">Back to List</a>
            </div>
        </EditForm>
    }
</div>

@code {
    private MovieDto? _movie;
    private bool isLoading = true;
    private bool isSubmitting;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("BlazorApi");
            _movie = await client.GetFromJsonAsync<MovieDto>($"/api/movies/{Id}");

            if (_movie is null)
            {
                NavigationManager.NavigateTo("notfound");
            }
        }
        catch
        {
            NavigationManager.NavigateTo("notfound");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteMovie()
    {
        isSubmitting = true;

        try
        {
            var client = HttpClientFactory.CreateClient("BlazorApi");
            var response = await client.DeleteAsync($"/api/movies/{Id}");

            if (response.IsSuccessStatusCode || response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                NavigationManager.NavigateTo("/movies");
            }
        }
        catch
        {
            // Navigate back on error too — the movie may have been deleted already
            NavigationManager.NavigateTo("/movies");
        }
    }
}
