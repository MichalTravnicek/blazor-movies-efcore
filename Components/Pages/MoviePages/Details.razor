@page "/movies/details"
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@using BlazorWebAppMovies.Components.Shared

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <hr />
    @if (isLoading)
    {
        <p><em>Loading...</em></p>
    }
    else if (_movie is null)
    {
        <p><em>Movie not found.</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Poster</dt>
            <dd class="col-sm-10">
                @if (!string.IsNullOrEmpty(_movie.PosterUrl))
                {
                    <img src="@_movie.PosterUrl" alt="@_movie.Title poster"
                         class="img-fluid movie-poster-detail" style="max-height:400px;cursor:pointer;"
                         @onclick="() => OpenLightbox()" />
                }
                else
                {
                    <div class="text-muted">No poster available</div>
                }
            </dd>
            <dt class="col-sm-2">Title</dt>
            <dd class="col-sm-10">@_movie.Title</dd>
            <dt class="col-sm-2">Release Date</dt>
            <dd class="col-sm-10">@_movie.ReleaseDate</dd>
            <dt class="col-sm-2">Genre</dt>
            <dd class="col-sm-10">@_movie.Genre</dd>
            <dt class="col-sm-2">Price</dt>
            <dd class="col-sm-10">@_movie.Price</dd>
            <dt class="col-sm-2">Rating</dt>
            <dd class="col-sm-10">@_movie.Rating</dd>
        </dl>
        @if (!string.IsNullOrEmpty(_movie.PosterUrl))
        {
            <Lightbox @ref="lightbox">
                @if (isLightboxLoading)
                {
                    <div class="d-flex justify-content-center align-items-center" style="min-height:300px;">
                        <div class="spinner-border text-light" role="status" style="width:3rem;height:3rem;">
                            <span class="visually-hidden">Loading poster...</span>
                        </div>
                    </div>
                }
                <img src="@_movie.PosterUrl" alt="@_movie.Title poster"
                     class="img-fluid" style="max-height:80vh;@(isLightboxLoading ? "display:none;" : "")"
                     @onload="OnLightboxImageLoaded" />
            </Lightbox>
        }
        <div class="d-flex gap-1">
            <a href="@($"/movies/edit?id={_movie.Id}")" class="btn btn-warning btn-sm">Edit</a>
            @if (string.IsNullOrEmpty(_movie.PosterUrl))
            {
                <button class="btn btn-outline-info btn-sm" @onclick="FetchPoster" disabled="@isFetchingPoster">
                    @if (isFetchingPoster)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Fetch Poster
                </button>
            }
            <a href="@($"/movies")" class="btn btn-outline-secondary btn-sm">Back to List</a>
        </div>
    }
</div>

@code {
    private MovieDto? _movie;
    private bool isLoading = true;
    private bool isFetchingPoster;
    private bool isLightboxLoading;
    private bool _pendingLightboxOpen;
    private Lightbox? lightbox;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("BlazorApi");
            _movie = await client.GetFromJsonAsync<MovieDto>($"/api/movies/{Id}");

            if (_movie is null)
            {
                NavigationManager.NavigateTo("/notfound");
            }
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            NavigationManager.NavigateTo("/notfound");
        }
        catch
        {
            // Stay on page — _movie stays null, UI shows "Movie not found."
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task FetchPoster()
    {
        if (_movie is null) return;
        isFetchingPoster = true;

        try
        {
            var client = HttpClientFactory.CreateClient("BlazorApi");
            var response = await client.PostAsync($"/api/movies/{_movie.Id}/poster/fetch", null);
            if (response.IsSuccessStatusCode)
            {
                _movie = await response.Content.ReadFromJsonAsync<MovieDto>();
            }
        }
        catch
        {
            // Stay on page with current state
        }
        finally
        {
            isFetchingPoster = false;
        }
    }

    private void OpenLightbox()
    {
        Console.WriteLine($"[Details] OpenLightbox: lightbox ref is null? {lightbox is null}");
        isLightboxLoading = true;
        _pendingLightboxOpen = true;
        Console.WriteLine("[Details] Set _pendingLightboxOpen=true, waiting for OnAfterRender");
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (_pendingLightboxOpen)
        {
            Console.WriteLine($"[Details] OnAfterRender: lightbox ref is null? {lightbox is null}, calling Open()");
            if (lightbox is not null)
            {
                _pendingLightboxOpen = false;
                lightbox.Open();
            }
            else
            {
                Console.WriteLine("[Details] WARNING: lightbox ref still null after render!");
            }
        }
    }

    private void OnLightboxImageLoaded()
    {
        Console.WriteLine("[Details] Lightbox image loaded, hiding spinner");
        isLightboxLoading = false;
        StateHasChanged();
    }
}
